{
  "name": "yaliai-canvas-oss",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @yali/web dev",
    "dev:api": "pnpm --filter @yali/api dev",
    "dev:admin": "pnpm --filter @yali/admin dev",
    "check": "pnpm check:canvas:utf8 && pnpm -r check",
    "check:canvas:utf8": "node scripts/check-canvas-utf8.mjs",
    "verify:upstream-safety": "node scripts/verify-upstream-safety.mjs"
  }
}
